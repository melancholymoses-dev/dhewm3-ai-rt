{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 23,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "vs2022-x64",
            "displayName": "VS 2022 x64",
            "description": "Configure dhewm3_rt with Vulkan using local third-party libs",
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "binaryDir": "${sourceDir}/../../build_rt",
            "cacheVariables": {
                "DHEWM3LIBS": "${sourceDir}/../../dhewm3-libs/x86_64-w64-mingw32",
                "CMAKE_PREFIX_PATH": "${sourceDir}/../../dhewm3-libs/x86_64-w64-mingw32",
                "OPENAL_INCLUDE_DIR": "${sourceDir}/../../dhewm3-libs/x86_64-w64-mingw32/include",
                "OPENAL_LIBRARY": "${sourceDir}/../../dhewm3-libs/x86_64-w64-mingw32/lib/OpenAL32.lib"
            },
            "environment": {
                "PATH": "$penv{PATH};${sourceDir}/../../dhewm3-libs/x86_64-w64-mingw32/bin"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "release",
            "displayName": "Build Release",
            "configurePreset": "vs2022-x64",
            "configuration": "Release"
        },
        {
            "name": "debug",
            "displayName": "Build Debug",
            "configurePreset": "vs2022-x64",
            "configuration": "Debug"
        }
    ]
}